---
import { CONTACT } from '../data/content';
---

<section id="kontakt">
  <div class="contact-grid">
    <div class="contact-left">
      <p class="eyebrow">Kontakt</p>
      <h2>Do <em>zobaczenia</em>.</h2>
      <p class="contact-lead">
        Najszybciej zarezerwujesz wizytę przez Booksy. Możesz też zadzwonić — chętnie doradzę,
        który masaż wybrać.
      </p>
      <div class="contact-ctas">
        <a href={CONTACT.booksy} target="_blank" rel="noopener noreferrer" class="btn-light">
          Booksy
        </a>
        <a href={CONTACT.phoneHref} class="btn-outline">
          Zadzwoń
        </a>
      </div>
    </div>

    <div class="contact-right">
      <div class="info-block">
        <p class="info-label">Adres</p>
        <p class="info-value">
          {CONTACT.street}<br />{CONTACT.zip} · {CONTACT.district}
        </p>
      </div>
      <div class="info-block">
        <p class="info-label">Telefon</p>
        <a href={CONTACT.phoneHref} class="info-phone">{CONTACT.phone}</a>
      </div>
      <div class="info-block">
        <p class="info-label">Godziny</p>
        <div class="hours-list">
          {CONTACT.hours.map((h, i) => (
            <div class={`hours-row${i < CONTACT.hours.length - 1 ? ' has-border' : ''}`}>
              <span>{h.day}</span>
              <em>{h.time}</em>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <footer class="contact-footer">
    <span>HarmonySpace · 2026</span>
    <em>Oddech. Dotyk. Cisza.</em>
  </footer>
</section>

<style>
  section {
    padding: 120px 80px;
    background: #4a5a3a;
    color: #faf6ee;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    max-width: 1120px;
    margin: 0 auto;
  }

  .eyebrow {
    font-size: 13px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #c9d3b8;
    margin: 0 0 24px;
    font-weight: 500;
  }

  h2 {
    font-size: clamp(48px, 5.3vw, 68px);
    margin: 0 0 40px;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }

  h2 em {
    color: #e8dfc9;
    font-style: italic;
  }

  .contact-lead {
    font-size: 20px;
    line-height: 1.6;
    color: #e8e3d3;
    margin: 0 0 40px;
    font-weight: 300;
    max-width: 440px;
  }

  .contact-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-light {
    background: #faf6ee;
    color: #4a5a3a;
    padding: 18px 36px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 600;
  }

  .btn-outline {
    border: 1px solid #faf6ee;
    color: #faf6ee;
    padding: 18px 36px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
  }

  .contact-right {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .info-block {
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: 28px;
  }

  .info-label {
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #c9d3b8;
    margin: 0 0 10px;
  }

  .info-value {
    font-size: 26px;
    font-weight: 400;
    line-height: 1.4;
    margin: 0;
  }

  .info-phone {
    font-size: 30px;
    color: #faf6ee;
    text-decoration: none;
    font-weight: 400;
  }

  .hours-list {
    display: flex;
    flex-direction: column;
  }

  .hours-row {
    display: flex;
    justify-content: space-between;
    font-size: 18px;
    padding: 8px 0;
    font-weight: 300;
  }

  .hours-row.has-border {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hours-row em {
    font-style: italic;
  }

  .contact-footer {
    max-width: 1120px;
    margin: 100px auto 0;
    padding-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: #c9d3b8;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .contact-footer em {
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.05em;
    font-size: 16px;
  }

  @media (max-width: 900px) {
    section {
      padding: 80px 40px;
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }

    .contact-footer {
      flex-direction: column;
      gap: 12px;
      text-align: center;
      margin-top: 60px;
    }
  }

  @media (max-width: 600px) {
    section {
      padding: 60px 24px;
    }
  }
</style>
