---
import { CONTACT } from '../data/content';
---

<section id="hero">
  <div class="hero-text">
    <p class="hero-eyebrow">Gabinet masażu · Warszawa Wawer</p>
    <h1>
      Oddech.<br />
      <em>Dotyk.</em><br />
      Cisza.
    </h1>
    <p class="hero-lead">
      Kameralne miejsce, gdzie woń naturalnych olejków, przygaszone światło i świadomy dotyk
      spotykają się z wiedzą fizjoterapeuty.
    </p>
    <div class="hero-ctas">
      <a href={CONTACT.booksy} target="_blank" rel="noopener noreferrer" class="btn-primary">
        Umów wizytę
      </a>
      <a href={CONTACT.phoneHref} class="btn-phone">
        {CONTACT.phone}
      </a>
    </div>
  </div>

  <div class="hero-images">
    <div class="hero-tilde" aria-hidden="true">~</div>
    <img
      src="/assets/gallery/05-mirror.jpeg"
      alt="Okrągłe lustro, kącik relaksu"
      class="hero-img-main"
      loading="eager"
    />
    <img
      src="/assets/gallery/03-candle.jpeg"
      alt="Świeca i naturalne olejki"
      class="hero-img-accent"
      loading="eager"
    />
  </div>
</section>

<div class="divider" aria-hidden="true">
  <div class="divider-line"></div>
  <span>regeneracja dla ciała i ducha</span>
  <div class="divider-line"></div>
</div>

<style>
  section {
    min-height: 780px;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 80px;
    padding: 160px 80px 120px;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    font-size: 13px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #6b7d5c;
    margin: 0 0 32px;
    font-weight: 500;
  }

  h1 {
    font-size: clamp(60px, 7.2vw, 92px);
    line-height: 0.98;
    font-weight: 400;
    margin: 0 0 36px;
    letter-spacing: -0.02em;
    font-family: 'Cormorant Garamond', serif;
  }

  h1 em {
    color: #4a5a3a;
    font-style: italic;
  }

  .hero-lead {
    font-size: 22px;
    line-height: 1.55;
    color: #5a5a52;
    max-width: 480px;
    margin: 0 0 48px;
    font-weight: 300;
  }

  .hero-ctas {
    display: flex;
    gap: 20px;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: #4a5a3a;
    color: #faf6ee;
    padding: 18px 38px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
  }

  .btn-phone {
    color: #2a2a26;
    padding: 18px 0;
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px solid #2a2a26;
    font-weight: 500;
  }

  .hero-images {
    position: relative;
    height: 640px;
  }

  .hero-tilde {
    position: absolute;
    top: 30px;
    left: 10px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 150px;
    color: #d8cfb8;
    font-style: italic;
    line-height: 1;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }

  .hero-img-main {
    position: absolute;
    top: 0;
    right: 60px;
    width: 460px;
    height: 580px;
    object-fit: cover;
    object-position: center;
    z-index: 1;
  }

  .hero-img-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 220px;
    height: 280px;
    object-fit: cover;
    border: 8px solid #faf6ee;
    z-index: 2;
  }

  .divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 0 80px 60px;
    max-width: 1280px;
    margin: 0 auto;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: #d8cfb8;
  }

  .divider span {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 20px;
    color: #6b7d5c;
    white-space: nowrap;
  }

  @media (max-width: 1024px) {
    section {
      grid-template-columns: 1fr;
      gap: 60px;
      padding: 140px 40px 80px;
      min-height: auto;
    }

    .hero-images {
      height: 420px;
    }

    .hero-img-main {
      width: 100%;
      right: 0;
      height: 380px;
    }

    .hero-img-accent {
      display: none;
    }

    .divider {
      padding: 0 40px 40px;
    }
  }

  @media (max-width: 600px) {
    section {
      padding: 120px 24px 60px;
    }

    .hero-lead {
      font-size: 18px;
    }

    .divider {
      padding: 0 24px 40px;
    }

    .divider span {
      font-size: 16px;
    }
  }
</style>
